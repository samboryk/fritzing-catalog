            <title>Назва: MCP4725 (12-біт ЦАП I2C)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51293" x="5950" y="44500"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1713" path=":/resources/parts/core/note.fzp">
            <title>Note364</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MCP4725 (12-біт ЦАП I2C)&lt;/b&gt;&lt;br/&gt;Опис: Компактний цифро-аналоговий перетворювач з інтерфейсом I2C. Має вбудовану EEPROM пам'ять для збереження вихідного рівня при ввімкненні. Використовується для точного програмного регулювання потужності або звукових ефектів.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
