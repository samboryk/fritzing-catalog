            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50821" x="5100" y="65850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-DiscreteSemi-DIODE-ZENER--BZT52" modelIndex="2185" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-discretesemi-diode-zener--bzt52.fzp" flippedSMD="true">
