        <instance moduleIdRef="NoteModuleID" modelIndex="1705" path=":/resources/parts/core/note.fzp">
            <title>Note360</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: AD7302 (Подвійний ЦАП 8-біт)&lt;/b&gt;&lt;br/&gt;Опис: Двоканальний цифро-аналоговий перетворювач (DAC). Дозволяє мікроконтролеру генерувати реальну аналогову напругу. Має паралельний інтерфейс для дуже швидкого оновлення вихідного сигналу, що підходить для генераторів сигналів складної форми.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.513" x="2550" y="44750" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
