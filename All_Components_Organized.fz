        <instance moduleIdRef="NoteModuleID" modelIndex="2868" path=":/resources/parts/core/note.fzp">
            <title>Note946</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Arduino Ethernet Shield (W5100)&lt;/b&gt;&lt;br/&gt;Опис: Класичний мережевий модуль. Дозволяє підключити Arduino до локальної мережі через кабель RJ45. Підтримує стеки TCP/UDP, ідеально для систем IoT та віддалених сенсорів.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
