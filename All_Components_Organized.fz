            <title>Назва: BASIC Stamp 2e (Module)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51461" x="1700" y="32700"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1545" path=":/resources/parts/core/note.fzp">
            <title>Note278</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: BASIC Stamp 2e (Module)&lt;/b&gt;&lt;br/&gt;Опис: Енергоефективна версія класичного BASIC Stamp 2. Оптимізована для роботи в автономних системах з живленням від батарей. Містить вбудований інтерпретатор PBASIC та пам'ять EEPROM для збереження програм та даних навіть після вимкнення живлення.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.5146" x="1700" y="32950" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
