                    <geometry z="2.51388" x="7650" y="36000"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1618" path=":/resources/parts/core/note.fzp">
            <title>Note315</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: I2C EEPROM 24LC128&lt;/b&gt;&lt;br/&gt;Опис: Популярна пам'ять на 128 Кбіт. Часто використовується як додаткове сховище для реєстраторів даних (data loggers) у метеостанціях.&lt;/body&gt;&lt;/html&gt;</text>
