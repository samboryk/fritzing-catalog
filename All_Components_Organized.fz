            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.50184" x="2550" y="96600"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2822" path=":/resources/parts/core/note.fzp">
            <title>Note923</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MyoWare Power Shield&lt;/b&gt;&lt;br/&gt;Опис: Силовий модуль для датчика MyoWare. Містить роз'єм для маленької батарейки-таблетки, що дозволяє датчику працювати автономно. Це усуває мережеві наведення (шуми 50Гц) від розетки, значно підвищуючи точність вимірювання біосигналів.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50183" x="2550" y="96850" width="650" height="180"/>
                </breadboardView>
            </views>
