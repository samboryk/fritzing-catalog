        <instance moduleIdRef="NoteModuleID" modelIndex="2820" path=":/resources/parts/core/note.fzp">
            <title>Note922</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MyoWare Cable Shield&lt;/b&gt;&lt;br/&gt;Опис: Модуль підключення для електроміографічного датчика MyoWare. Дозволяє винести електроди за допомогою кабелів, що необхідно для стабільного зняття сигналів м'язової активності, коли основна плата заважає руху.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
