        <instance moduleIdRef="NoteModuleID" modelIndex="2107" path=":/resources/parts/core/note.fzp">
            <title>Note562</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: WS2801 (Драйвер розумних LED)&lt;/b&gt;&lt;br/&gt;Опис: Мікросхема для створення адресних світлодіодних стрічок. Дозволяє керувати кольором кожного окремого RGB-світлодіода за допомогою SPI-подібного інтерфейсу.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50898" x="850" y="61850" width="650" height="180"/>
