        <instance moduleIdRef="NoteModuleID" modelIndex="2880" path=":/resources/parts/core/note.fzp">
            <title>Note952</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: XPort Direct Module&lt;/b&gt;&lt;br/&gt;Опис: Версія XPort для поверхневого монтажу. Має мініатюрні розміри та вбудований стек протоколів TCP/IP, що дозволяє швидко розробляти мережеві промислові пристрої.&lt;/body&gt;&lt;/html&gt;</text>
