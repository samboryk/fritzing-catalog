        <instance moduleIdRef="NoteModuleID" modelIndex="1696" path=":/resources/parts/core/note.fzp">
            <title>Note355</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Rotoshield v1.0a (Motor Driver Shield)&lt;/b&gt;&lt;br/&gt;Опис: Універсальний драйвер для керування двигунами. Здатний одночасно контролювати декілька крокових двигунів або двигунів постійного струму (DC). Має вбудовані захисні діоди та роз'єми для підключення датчиків, що робить його базовою платформою для побудови складних колісних роботів та маніпуляторів.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51309" x="2550" y="42850" width="650" height="180"/>
                </breadboardView>
