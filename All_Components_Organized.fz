            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51879" x="0" y="9400"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1127" path=":/resources/parts/core/note.fzp">
            <title>Note66</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: TPA2000D1 Audio Amplifier (Аудіопідсилювач класу D)&lt;/b&gt;&lt;br/&gt;Опис: Монофонічний безфільтровий підсилювач потужності звукової частоти (2 Вт). Працює за технологією класу D, що забезпечує надвисокий ККД і мінімальне нагрівання. Ідеальний для портативних колонок, мобільних гаджетів та голосового озвучення подій у робототехніці.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51878" x="0" y="9650" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
