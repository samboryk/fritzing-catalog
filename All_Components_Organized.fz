        <instance moduleIdRef="NoteModuleID" modelIndex="1989" path=":/resources/parts/core/note.fzp">
            <title>Note503</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: 74HC595 (Регістр зсуву)&lt;/b&gt;&lt;br/&gt;Опис: Легендарна мікросхема для розширення виходів Arduino. Дозволяє керувати 8-ма світлодіодами, використовуючи лише 3 цифрові лінії. Можуть з'єднуватися послідовно для керування сотнями виходів.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51016" x="1700" y="57650" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
