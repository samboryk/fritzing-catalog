            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51321" x="0" y="40700"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1685" path=":/resources/parts/core/note.fzp">
            <title>Note349</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Grove Digital Accelerometer (±16g)&lt;/b&gt;&lt;br/&gt;Опис: Трьохосьовий цифровий акселерометр на базі ADXL345. Працює через інтерфейс I2C. Здатний вимірювати статичне прискорення (нахил) та динамічне (рух, удар, вібрація). Застосовується в ігрових контролерах, системах виявлення вільного падіння та крокомірах.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.5132" x="0" y="40950" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
