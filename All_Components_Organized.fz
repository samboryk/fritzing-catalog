                    <geometry z="2.5192" x="850" y="6100"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1086" path=":/resources/parts/core/note.fzp">
            <title>Note45</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Serial Port Multiplexer (8-way)&lt;/b&gt;&lt;br/&gt;Опис: Інтелектуальний розгалужувач послідовного порту. Дозволяє підключити до одного UART-інтерфейсу мікроконтролера до 8 різних сенсорів Atlas Scientific. Вирішує проблему обмеженої кількості апаратних портів, забезпечуючи надійне перемикання ліній передачі даних.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51919" x="850" y="6350" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="atlas-sientific_pH Circuit" modelIndex="1087" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/atlas-sientific_pH Circuit.fzp">
            <title>Назва: pH Circuit (EZO-клас)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51918" x="1700" y="6100"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1088" path=":/resources/parts/core/note.fzp">
            <title>Note46</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: pH Circuit (EZO-клас)&lt;/b&gt;&lt;br/&gt;Опис: Професійний мікропроцесорний модуль для вимірювання кислотності (pH) рідин. Забезпечує лабораторну точність і стабільність показників. Перетворює складні аналогові сигнали від pH-електрода у цифрові дані (UART або I2C), підтримуючи температурну компенсацію та багатоточкове калібрування.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
