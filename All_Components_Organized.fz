        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1715" path=":/resources/parts/core/note.fzp">
            <title>Note365</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: TS3A5017 (Аналоговий мультиплексор)&lt;/b&gt;&lt;br/&gt;Опис: Подвійний чотириканальний високошвидкісний аналоговий перемикач. Дозволяє комутувати аудіо або низьковольтні сигнали даних між різними входами/виходами з мінімальними завадами. Має дуже низький опір у відкритому стані.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.5129" x="6800" y="44750" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
