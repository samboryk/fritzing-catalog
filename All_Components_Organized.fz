            <title>Назва: PQ1CY1032Z (Потужний Buck)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.50529" x="850" y="80400"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2477" path=":/resources/parts/core/note.fzp">
            <title>Note749</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: PQ1CY1032Z (Потужний Buck)&lt;/b&gt;&lt;br/&gt;Опис: Промисловий імпульсний стабілізатор у корпусі з гарним відведенням тепла. Використовується в блоках живлення стаціонарної електроніки.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50528" x="850" y="80650" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
