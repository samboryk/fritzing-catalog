        <instance moduleIdRef="NoteModuleID" modelIndex="1125" path=":/resources/parts/core/note.fzp">
            <title>Note65</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: SN74HC14 Hex Inverter (Інвертор з тригером Шмітта)&lt;/b&gt;&lt;br/&gt;Опис: Логічна мікросхема, що містить 6 інверторів (елементів НЕ). Завдяки вбудованим тригерам Шмітта, вона ефективно перетворює повільні або зашумлені аналогові сигнали в чіткі цифрові імпульси. Незамінна для усунення 'брязкоту' контактів механічних кнопок.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.5188" x="7650" y="8950" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="1de0685180965d3848aca197945d624e" modelIndex="1126" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/TPA2000D1 Audio Amplifier dip double.fzp">
