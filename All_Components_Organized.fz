        <instance moduleIdRef="NoteModuleID" modelIndex="1699" path=":/resources/parts/core/note.fzp">
            <title>Note357</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MAX6675 (Конвертор Темопара-Цифра)&lt;/b&gt;&lt;br/&gt;Опис: Спеціалізована мікросхема для роботи з термопарами типу K. Виконує компенсацію холодного спаю та перетворює аналоговий сигнал температури у 12-бітний цифровий код для читання через SPI. Діапазон: від 0°C до +1024°C. Ідеально для 3D-принтерів та промислових печей.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51306" x="0" y="44750" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-AnalogIC-LM393-" modelIndex="1700" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-analogic-lm393-.fzp" flippedSMD="true">
            <title>Назва: LM393 (Подвійний компаратор)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51305" x="850" y="44500"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1701" path=":/resources/parts/core/note.fzp">
            <title>Note358</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: LM393 (Подвійний компаратор)&lt;/b&gt;&lt;br/&gt;Опис: Низькоспоживаючий здвоєний компаратор напруги. Порівнює два аналогових сигнали і видає цифровий логічний рівень залежно від того, який вхід більший. Основний компонент для датчиків світла, звуку чи вологості з цифровим виходом (D0).&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51304" x="850" y="44750" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-AnalogIC-MSGEQ7-SOIC" modelIndex="1702" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-analogic-msgeq7-soic.fzp" flippedSMD="true">
            <title>Назва: MSGEQ7 (Графічний еквалайзер)</title>
            <views>
