                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1654" path=":/resources/parts/core/note.fzp">
            <title>Note333</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: RTC DS1307 (I2C Clock)&lt;/b&gt;&lt;br/&gt;Опис: Популярний модуль годинника з інтерфейсом I2C. Має вбудовану пам'ять на 56 байт для збереження користувацьких даних та автоматично враховує високосні роки.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
