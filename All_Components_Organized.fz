        <instance moduleIdRef="SparkFun-AnalogIC-MAX6675-" modelIndex="1698" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-analogic-max6675-.fzp" flippedSMD="true">
            <title>Назва: MAX6675 (Конвертор Темопара-Цифра)</title>
            <views>
                <breadboardView layer="breadboard">
