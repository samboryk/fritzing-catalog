            <title>Назва: HT8950 (Модулятор голосу)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51285" x="850" y="45200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1721" path=":/resources/parts/core/note.fzp">
