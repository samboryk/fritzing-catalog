        <instance moduleIdRef="NoteModuleID" modelIndex="2160" path=":/resources/parts/core/note.fzp">
            <title>Note589</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: TVS Diode (Супресор)&lt;/b&gt;&lt;br/&gt;Опис: Напівпровідниковий прилад для захисту від перенапруг. Миттєво переходить у провідний стан при перевищенні порогової напруги, шунтуючи небезпечний імпульс на землю. Обов'язковий елемент для захисту USB-портів та ліній живлення.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50845" x="3400" y="65150" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
