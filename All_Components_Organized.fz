        <instance moduleIdRef="NoteModuleID" modelIndex="1098" path=":/resources/parts/core/note.fzp">
            <title>Note51</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Conductivity Circuit (Електропровідність)&lt;/b&gt;&lt;br/&gt;Опис: Модуль для вимірювання провідності води, загальної кількості розчинених солей (TDS) та солоності. Незамінний інструмент для гідропоніки, акваріумістики та промислового контролю очищення стічних вод. Автоматично конвертує мікросіменси в одиниці концентрації солей.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51907" x="5950" y="6350" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
