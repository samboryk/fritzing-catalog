        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1576" path=":/resources/parts/core/note.fzp">
            <title>Note294</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: PICAXE-20X2 (High Speed)&lt;/b&gt;&lt;br/&gt;Опис: Високошвидкісний контролер нового покоління. Може працювати на частоті до 64 МГц, підтримує апаратне переривання та складні обчислення в реальному часі.&lt;/body&gt;&lt;/html&gt;</text>
