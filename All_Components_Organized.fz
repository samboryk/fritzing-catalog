        <instance moduleIdRef="NoteModuleID" modelIndex="2005" path=":/resources/parts/core/note.fzp">
            <title>Note511</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: PIC16F688 (Компактний 14-пін МК)&lt;/b&gt;&lt;br/&gt;Опис: Малогабаритний контролер із гарним набором периферії. Часто використовується в автомобільній електроніці та простих споживчих гаджетах у SMD виконанні.&lt;/body&gt;&lt;/html&gt;</text>
