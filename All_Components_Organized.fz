            <title>Назва: AD9835 (Генератор сигналів DDS)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51297" x="4250" y="44500"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1709" path=":/resources/parts/core/note.fzp">
            <title>Note362</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: AD9835 (Генератор сигналів DDS)&lt;/b&gt;&lt;br/&gt;Опис: Прецизійний цифровий синтезатор частоти. Здатний генерувати чисті синусоїдальні та прямокутні сигнали з високою точністю (до 50 МГц). Керується через SPI. Застосування: випробувальне обладнання та засоби радіозв'язку.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51296" x="4250" y="44750" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
