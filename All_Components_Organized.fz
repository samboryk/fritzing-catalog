        <instance moduleIdRef="NoteModuleID" modelIndex="2091" path=":/resources/parts/core/note.fzp">
            <title>Note554</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: PL-2303 (USB-to-Serial Bridge)&lt;/b&gt;&lt;br/&gt;Опис: Поширений перетворювач інтерфейсів від Prolific. Використовується в бюджетних дата-кабелях та перехідниках USB-COM для зв'язку комп'ютера з мікроконтролерами.&lt;/body&gt;&lt;/html&gt;</text>
