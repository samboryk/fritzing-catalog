        <instance moduleIdRef="NoteModuleID" modelIndex="1983" path=":/resources/parts/core/note.fzp">
            <title>Note500</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: CP2103 (USB-UART з GPIO)&lt;/b&gt;&lt;br/&gt;Опис: Вдосконалений міст USB-Serial. Окрім передачі даних, має 4 піни GPIO, якими можна керувати безпосередньо з комп'ютера через драйвер, що корисно для скидання (Reset) контролерів.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51022" x="7650" y="56950" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
