        <instance moduleIdRef="NoteModuleID" modelIndex="2149" path=":/resources/parts/core/note.fzp">
            <title>Note583</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: 74HC157 (Квадратичний мультиплексор)&lt;/b&gt;&lt;br/&gt;Опис: Логічна мікросхема, що дозволяє вибирати між двома групами по 4 цифрові сигнали. Часто застосовується для перемикання шин даних між двома джерелами.&lt;/body&gt;&lt;/html&gt;</text>
