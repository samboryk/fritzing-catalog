            <title>Назва: LM358 (Подвійний ОП)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51299" x="3400" y="44500"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1707" path=":/resources/parts/core/note.fzp">
            <title>Note361</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: LM358 (Подвійний ОП)&lt;/b&gt;&lt;br/&gt;Опис: Універсальний двоканальний операційний підсилювач. Найпоширеніша мікросхема для підсилення сигналів датчиків, створення аналогових фільтрів та буферів. Працює від однополярного живлення (наприклад, 5В від Arduino).&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51298" x="3400" y="44750" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
