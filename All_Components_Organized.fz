        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2235" path=":/resources/parts/core/note.fzp">
            <title>Note627</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Потенціометр із вимикачем&lt;/b&gt;&lt;br/&gt;Опис: Комбінований компонент: регулятор опору та механічний вимикач в одному корпусі. Типове застосування — ручка гучності в радіоприймачах, де перше клацання вмикає пристрій.&lt;/body&gt;&lt;/html&gt;</text>
