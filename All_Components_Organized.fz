            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.50828" x="2550" y="65600"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2178" path=":/resources/parts/core/note.fzp">
            <title>Note598</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: N-Channel MOSFET (SOIC-8)&lt;/b&gt;&lt;br/&gt;Опис: Потужний польовий ключ у корпусі для поверхневого монтажу. Використовується в ролі 'нижнього ключа' (Low-side switch). Завдяки високій швидкості перемикання ідеально підходить для ШІМ (PWM) керування яскравістю або швидкістю двигунів.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50827" x="2550" y="65850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-DiscreteSemi-TRANSISTOR_NPN-TO-92-AMMO" modelIndex="2179" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-discretesemi-transistor_npn-to-92-ammo.fzp">
