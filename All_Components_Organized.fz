        <instance moduleIdRef="NoteModuleID" modelIndex="1092" path=":/resources/parts/core/note.fzp">
            <title>Note48</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: RJ-11 Sensor Breakout&lt;/b&gt;&lt;br/&gt;Опис: Спеціалізована плата-перехідник для підключення датчиків із роз'ємом RJ-11 (наприклад, лічильників потоку рідини чи метеорологічних приладів). Забезпечує надійний електричний контакт і зручне розведення сигнальних ліній на стандартні штирі макетної плати.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51913" x="3400" y="6350" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="atlas-sientific_FLO-30 Circuit" modelIndex="1093" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/atlas-sientific_FLO-30 Circuit.fzp">
            <title>Назва: FLO-30 (Контролер потоку рідини)</title>
            <views>
                <breadboardView layer="breadboard">
