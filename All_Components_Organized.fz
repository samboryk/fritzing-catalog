        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1541" path=":/resources/parts/core/note.fzp">
            <title>Note276</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Parallax Propeller P8X32A (D40)&lt;/b&gt;&lt;br/&gt;Опис: Унікальний восьмиядерний 32-бітний мікроконтролер. Кожне з 8 ядер (cogs) може працювати незалежно на частоті до 80 МГц, що дозволяє виконувати паралельні завдання (наприклад, генерацію відеосигналу, керування двигунами та опитування сенсорів) без використання переривань. Програмується мовами Spin або Assembly.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51464" x="0" y="32950" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="760832bc79fe1f34e99f420ad872a0b8" modelIndex="1542" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/BASIC_Stamp_2.fzp">
            <title>Назва: BASIC Stamp 2sx (Module)</title>
            <views>
                <breadboardView layer="breadboard">
