        <instance moduleIdRef="NoteModuleID" modelIndex="1660" path=":/resources/parts/core/note.fzp">
            <title>Note336</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Драйвер двигунів L293D (H-Bridge)&lt;/b&gt;&lt;br/&gt;Опис: Силова мікросхема для керування індуктивними навантаженнями. Здатна керувати двома потужними двигунами одночасно або одним кроковим двигуном. Має вбудовані захисні діоди.&lt;/body&gt;&lt;/html&gt;</text>
