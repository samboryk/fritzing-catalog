        <instance moduleIdRef="NoteModuleID" modelIndex="1002" path=":/resources/parts/core/note.fzp">
            <title>Note2</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: AD8226 (Інструментальний підсилювач)&lt;/b&gt;&lt;br/&gt;Опис: Високоточний інструментальний підсилювач із виходом Rail-to-Rail. Працює з широким діапазоном напруг (від 2.2В до 36В). Незамінний для посилення сигналів низького рівня в умовах сильних електромагнітних завад. Застосування: прецизійні ваги, медичне ЕКГ-обладнання, моніторинг струму в промислових установках.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.52003" x="0" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_SSM2220S" modelIndex="1003" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_SSM2220.AnalogDevices_SSM2220S.fzp">
            <property name="part number" value="SSM2220"/>
            <title>Назва: SSM2220 (Аудіо-транзисторна пара PNP)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.52002" x="850" y="200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1004" path=":/resources/parts/core/note.fzp">
            <title>Note3</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: SSM2220 (Аудіо-транзисторна пара PNP)&lt;/b&gt;&lt;br/&gt;Опис: Узгоджена пара PNP транзисторів із надзвичайно низькою напругою шуму (0.7 нВ/√Гц). Забезпечує ідеальний баланс характеристик обох каналів. Використовується як вхідний каскад у студійній аудіоапаратурі, мікрофонних підсилювачах та вимірювальних приладах, де шум звичайних транзисторів є неприпустимим.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.52001" x="850" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_SSM2212RZ" modelIndex="1005" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_SSM2212.AnalogDevices_SSM2212RZ.fzp">
            <property name="part number" value="SSM2212"/>
            <title>Назва: SSM2212 (Аудіо-транзисторна пара NPN)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.52" x="1700" y="200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1006" path=":/resources/parts/core/note.fzp">
            <title>Note4</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: SSM2212 (Аудіо-транзисторна пара NPN)&lt;/b&gt;&lt;br/&gt;Опис: Комплементарна пара до SSM2220, але на базі NPN-структури. Має ідентичні теплові та електричні характеристики між транзисторами в одному корпусі. Призначена для побудови високолінійних логарифмічних перетворювачів, підсилювачів з низьким дрейфом та професійних дискретних операційних підсилювачів.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51999" x="1700" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_ADTL082ARZ" modelIndex="1007" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_ADTL082.AnalogDevices_ADTL082ARZ.fzp">
            <property name="part number" value="ADTL082"/>
            <title>Назва: ADTL082 (JFET Операційний підсилювач)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51998" x="2550" y="200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1008" path=":/resources/parts/core/note.fzp">
            <title>Note5</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: ADTL082 (JFET Операційний підсилювач)&lt;/b&gt;&lt;br/&gt;Опис: Двоканальний ОП із входами на польових транзисторах (JFET). Завдяки високому вхідному опору (ТераОми) він практично не навантажує джерело сигналу. Сценарії використання: активні фільтри звукових частот, фотодіодні підсилювачі, буфери для датчиків з високим внутрішнім опором.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51997" x="2550" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_AD8541ARZ" modelIndex="1009" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_AD8541.AnalogDevices_AD8541ARZ.fzp">
            <property name="part number" value="AD8541"/>
            <title>Назва: AD8541 (Мікропотужний ОП Rail-to-Rail)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51996" x="3400" y="200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1010" path=":/resources/parts/core/note.fzp">
            <title>Note6</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: AD8541 (Мікропотужний ОП Rail-to-Rail)&lt;/b&gt;&lt;br/&gt;Опис: Одиночний операційний підсилювач, оптимізований для живлення від однієї батарейки (2.7В – 5.5В). Споживає мінімальний струм (45 мкА), підтримуючи повний розмах сигналу на вході та виході. Ідеальний для портативних вимірювачів, систем автономного моніторингу та датчиків диму.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51995" x="3400" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_ADP3300ARTZ" modelIndex="1011" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_ADP3300.AnalogDevices_ADP3300ARTZ.fzp">
            <property name="part number" value="ADP3300"/>
            <title>Назва: ADP3300 (Прецизійний LDO стабілізатор)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51994" x="4250" y="200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1012" path=":/resources/parts/core/note.fzp">
            <title>Note7</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: ADP3300 (Прецизійний LDO стабілізатор)&lt;/b&gt;&lt;br/&gt;Опис: Лінійний регулятор напруги з малим падінням (LDO) на 50 мА. Технологія AnyCAP дозволяє йому працювати стабільно навіть без зовнішнього вихідного конденсатора (хоча для кращих характеристик він рекомендований). Використовується для 'чистого' живлення чутливих АЦП та мікроконтролерів у вимірювальних приладах.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51993" x="4250" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_AD584JNZ" modelIndex="1013" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_AD584.AnalogDevices_AD584JNZ.fzp">
            <property name="part number" value="AD584"/>
            <title>Назва: AD584 (Еталонне джерело напруги)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51992" x="5100" y="200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1014" path=":/resources/parts/core/note.fzp">
            <title>Note8</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: AD584 (Еталонне джерело напруги)&lt;/b&gt;&lt;br/&gt;Опис: Прецизійне джерело опорної напруги (ІОН), що дозволяє програмувати вихід на 2.5В, 5В, 7.5В або 10В. Забезпечує стабільність напруги при зміні температури та вхідного живлення. Використовується як еталон для калібрування мультиметрів та систем збирання даних високої розрядності.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51991" x="5100" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_AD654JNZ" modelIndex="1015" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_AD654.AnalogDevices_AD654JNZ.fzp">
            <property name="part number" value="AD654"/>
            <title>Назва: AD654 (Перетворювач Напруга-Частота)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.5199" x="5950" y="200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1016" path=":/resources/parts/core/note.fzp">
            <title>Note9</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: AD654 (Перетворювач Напруга-Частота)&lt;/b&gt;&lt;br/&gt;Опис: Монолітна мікросхема, що перетворює аналогову напругу в серію цифрових імпульсів, частота яких пропорційна вхідному сигналу. Це дозволяє передавати дані від аналогових датчиків через оптопари або довгі дроти без втрати точності через падіння напруги.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51989" x="5950" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_AD8561ANZ" modelIndex="1017" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_AD8561.AnalogDevices_AD8561ANZ.fzp">
            <property name="part number" value="AD8561"/>
            <title>Назва: AD8561 (Надшвидкий компаратор)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51988" x="6800" y="200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1018" path=":/resources/parts/core/note.fzp">
            <title>Note10</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: AD8561 (Надшвидкий компаратор)&lt;/b&gt;&lt;br/&gt;Опис: Високошвидкісний компаратор із часом відгуку 7 нс. Здатний працювати з сигналом, частота якого досягає десятків мегагерц. Застосовується в схемах захисту від КЗ, логічних буферах, високошвидкісних лічильниках імпульсів та пристроях синхронізації фаз.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51987" x="6800" y="450" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="AnalogDevices_OP27GPZ" modelIndex="1019" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/ADI_OP27.AnalogDevices_OP27GPZ.fzp">
            <property name="part number" value="OP27"/>
            <title>Назва: OP27 (Легендарний прецизійний ОП)</title>
            <views>
                <breadboardView layer="breadboard">
