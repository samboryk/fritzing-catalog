        <instance moduleIdRef="NoteModuleID" modelIndex="2866" path=":/resources/parts/core/note.fzp">
            <title>Note945</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: XBee Shield (ZigBee)&lt;/b&gt;&lt;br/&gt;Опис: Плата для встановлення радіомодулів XBee. Забезпечує надійний цифровий радіозв'язок на великих відстанях. Має перемикач вибору апаратного або програмного послідовного порту.&lt;/body&gt;&lt;/html&gt;</text>
