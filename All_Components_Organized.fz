        <instance moduleIdRef="NoteModuleID" modelIndex="2156" path=":/resources/parts/core/note.fzp">
            <title>Note587</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MMDT3904 (Подвійний NPN транзистор)&lt;/b&gt;&lt;br/&gt;Опис: Два незалежні універсальні NPN транзистори 2N3904 в одному мініатюрному корпусі SOT-363. Використовується для економії місця на платі в схемах підсилення сигналу, логічних перемикачах або як драйвери для невеликих навантажень.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50849" x="1700" y="65150" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
