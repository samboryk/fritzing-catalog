            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.50925" x="6800" y="60200"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2081" path=":/resources/parts/core/note.fzp">
            <title>Note549</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: USB3318 (USB PHY)&lt;/b&gt;&lt;br/&gt;Опис: Мікросхема фізичного рівня для інтерфейсу USB Hi-Speed (480 Мбіт/с). Використовується разом із потужними процесорами або ПЛІС для реалізації високошвидкісного зв'язку з ПК.&lt;/body&gt;&lt;/html&gt;</text>
