                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1562" path=":/resources/parts/core/note.fzp">
            <title>Note287</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: PICAXE-08M&lt;/b&gt;&lt;br/&gt;Опис: Покращена версія 8-пінового контролера. Підтримує генерацію звуку (команда SOUND) та роботу з інфрачервоними пультами (команди INFRAIN/OUT). Чудовий вибір для створення мініатюрних керованих іграшок.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
