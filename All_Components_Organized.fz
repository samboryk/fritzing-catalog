        <instance moduleIdRef="NoteModuleID" modelIndex="2186" path=":/resources/parts/core/note.fzp">
            <title>Note602</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Стабілітрон (Діод Зенера, BZT52)&lt;/b&gt;&lt;br/&gt;Опис: Діод, призначений для стабілізації напруги. При зворотному ввімкненні підтримує на собі постійну напругу. Використовується для створення опорних джерел напруги або обмеження вхідних сигналів до безпечного рівня (наприклад, 3.3В чи 5.1В).&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50819" x="5950" y="65850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
