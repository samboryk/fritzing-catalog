        <instance moduleIdRef="NoteModuleID" modelIndex="2009" path=":/resources/parts/core/note.fzp">
            <title>Note513</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MAX7456 (OSD-генератор)&lt;/b&gt;&lt;br/&gt;Опис: Монохромний генератор екранного меню. Дозволяє накладати текстову та графічну інформацію (швидкість, висоту, заряд) поверх аналогового відеосигналу. Стандарт для FPV-дронів.&lt;/body&gt;&lt;/html&gt;</text>
