        <instance moduleIdRef="NoteModuleID" modelIndex="2174" path=":/resources/parts/core/note.fzp">
            <title>Note596</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MOC3031 (Оптосимістор із Zero-Cross)&lt;/b&gt;&lt;br/&gt;Опис: Оптопара для керування потужними симісторами (триаками). Має вбудовану схему детектування переходу напруги через нуль, що мінімізує радіоперешкоди та пускові струми при ввімкненні навантаження 220В (нагрівачі, лампи).&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50831" x="850" y="65850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-DiscreteSemi-TRANSISTOR_NPN_2-PTH" modelIndex="2175" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-discretesemi-transistor_npn_2-pth.fzp">
            <title>Назва: NPN Транзистор (Вивідний, PTH)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.5083" x="1700" y="65600"/>
