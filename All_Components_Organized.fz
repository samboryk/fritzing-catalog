        <instance moduleIdRef="NoteModuleID" modelIndex="2840" path=":/resources/parts/core/note.fzp">
            <title>Note932</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Arduino Mega ProtoShield&lt;/b&gt;&lt;br/&gt;Опис: Велика макетна плата, спеціально розроблена під форм-фактор Arduino Mega 2560. Надає величезне поле для пайки складних схем із великою кількістю мікросхем та датчиків.&lt;/body&gt;&lt;/html&gt;</text>
