            <title>Назва: WTV020 (Звуковий модуль)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.50897" x="1700" y="61600"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2109" path=":/resources/parts/core/note.fzp">
            <title>Note563</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: WTV020 (Звуковий модуль)&lt;/b&gt;&lt;br/&gt;Опис: Контролер для відтворення аудіофайлів з MicroSD карти. Оптимальний для додавання голосових підказок або звукових ефектів у проекти, де не потрібна якість MP3, а достатньо формату ADPCM.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50896" x="1700" y="61850" width="650" height="180"/>
                </breadboardView>
