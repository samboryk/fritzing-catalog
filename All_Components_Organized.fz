        <instance moduleIdRef="NoteModuleID" modelIndex="2461" path=":/resources/parts/core/note.fzp">
            <title>Note741</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: LMZ14203 (Power Module)&lt;/b&gt;&lt;br/&gt;Опис: Готовий модуль живлення 'все в одному' (регулятор + котушка індуктивності). Спрощує дизайн плат, оскільки не потребує складних розрахунків зовнішніх компонентів для імпульсного перетворення.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50544" x="2550" y="79950" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
