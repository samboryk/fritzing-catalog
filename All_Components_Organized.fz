            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51325" x="6800" y="40000"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1681" path=":/resources/parts/core/note.fzp">
            <title>Note347</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Grove Buzzer&lt;/b&gt;&lt;br/&gt;Опис: П'єзоелектричний випромінювач звуку (пищалка). Простий модуль для звукової індикації подій: натискання кнопок, завершення процесу або спрацювання тривоги. Може відтворювати прості мелодії шляхом зміни частоти вхідного сигналу.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51324" x="6800" y="40250" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
