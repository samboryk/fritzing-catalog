            <title>Назва: BASIC Stamp 2pe (Module)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51459" x="2550" y="32700"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1547" path=":/resources/parts/core/note.fzp">
            <title>Note279</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: BASIC Stamp 2pe (Module)&lt;/b&gt;&lt;br/&gt;Опис: Високоінтегрований модуль, розроблений для систем збору даних. Має розширену пам'ять EEPROM (32 КБ) для логування показників датчиків та додаткові команди для керування периферійними пристроями через шини I2C та 1-Wire.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51458" x="2550" y="32950" width="650" height="180"/>
                </breadboardView>
