        <instance moduleIdRef="NoteModuleID" modelIndex="2397" path=":/resources/parts/core/note.fzp">
            <title>Note709</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: LM5007 (Step-Down Регулятор)&lt;/b&gt;&lt;br/&gt;Опис: Високовольтний імпульсний понижуючий перетворювач (Buck). Здатний приймати вхідну напругу до 75В та видавати стабільний струм до 0.5А. Застосовується в промислових системах та телекомунікаційному обладнанні.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50608" x="850" y="77850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-PowerIC-MIC2571-SMD" modelIndex="2398" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-poweric-mic2571-smd.fzp" flippedSMD="true">
            <title>Назва: MIC2571 (Boost Регулятор)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.50607" x="1700" y="77600"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2399" path=":/resources/parts/core/note.fzp">
            <title>Note710</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MIC2571 (Boost Регулятор)&lt;/b&gt;&lt;br/&gt;Опис: Одноканальний підвищуючий імпульсний перетворювач, що працює від однієї або двох батарейок типу AA/AAA. Дозволяє отримати стабільні 3.3В або 5В для живлення мікроконтролера від розряджених елементів живлення.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50606" x="1700" y="77850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-PowerIC-ULN2803-SOICW" modelIndex="2400" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-poweric-uln2803-soicw.fzp" flippedSMD="true">
            <title>Назва: ULN2803 (Масив Дарлінгтона)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.50605" x="2550" y="77600"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2401" path=":/resources/parts/core/note.fzp">
            <title>Note711</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: ULN2803 (Масив Дарлінгтона)&lt;/b&gt;&lt;br/&gt;Опис: Восьмиканальна збірка потужних транзисторів для комутації навантаження. Дозволяє Arduino керувати реле, соленоїдами, кроковими двигунами та лампами з робочим струмом до 500мА на канал. Має вбудовані захисні діоди.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50604" x="2550" y="77850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-PowerIC-A4983-" modelIndex="2402" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-poweric-a4983-.fzp" flippedSMD="true">
            <title>Назва: A4983 (Драйвер крокового двигуна)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.50603" x="3400" y="77600"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="2403" path=":/resources/parts/core/note.fzp">
            <title>Note712</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: A4983 (Драйвер крокового двигуна)&lt;/b&gt;&lt;br/&gt;Опис: Професійний драйвер для біполярних крокових двигунів. Підтримує мікрокроковий режим (до 1/16 кроку) та має автоматичне регулювання струму. Попередник популярного A4988, широко використовувався в перших 3D-принтерах.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50602" x="3400" y="77850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
