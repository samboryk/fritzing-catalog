        <instance moduleIdRef="NoteModuleID" modelIndex="2079" path=":/resources/parts/core/note.fzp">
            <title>Note548</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: ATxmega-A3 (Просунутий 16-біт МК)&lt;/b&gt;&lt;br/&gt;Опис: Високопродуктивна лінійка AVR. Має вбудовані ЦАП (DAC), швидкі АЦП та криптографічний прискорювач. Для професійних проектів з високими вимогами до швидкості.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
