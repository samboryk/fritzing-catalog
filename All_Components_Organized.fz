        <instance moduleIdRef="NoteModuleID" modelIndex="2878" path=":/resources/parts/core/note.fzp">
            <title>Note951</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: XPort Serial-to-Ethernet&lt;/b&gt;&lt;br/&gt;Опис: Професійний вбудований сервер. Перетворює дані з послідовного порту (Serial) у мережеві пакети. Найпростіший спосіб вивести будь-який контролер в інтернет.&lt;/body&gt;&lt;/html&gt;</text>
