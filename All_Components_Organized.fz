        <instance moduleIdRef="NoteModuleID" modelIndex="2176" path=":/resources/parts/core/note.fzp">
            <title>Note597</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: NPN Транзистор (Вивідний, PTH)&lt;/b&gt;&lt;br/&gt;Опис: Класичний біполярний транзистор (наприклад, 2N2222 або BC547). Незамінний для макетування на breadboard. Основне призначення: підсилення струму мікроконтролера для керування реле, двигунами та потужними світлодіодами.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50829" x="1700" y="65850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-DiscreteSemi-MOSFET-NCHANNEL-SOIC8-" modelIndex="2177" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-discretesemi-mosfet-nchannel-soic8-.fzp" flippedSMD="true">
