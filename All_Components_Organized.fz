        <instance moduleIdRef="NoteModuleID" modelIndex="1673" path=":/resources/parts/core/note.fzp">
            <title>Note343</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Grove Light Sensor&lt;/b&gt;&lt;br/&gt;Опис: Аналоговий датчик освітленості на основі фоторезистора GL5528. Видає сигнал, пропорційний інтенсивності світла. Часто використовується у навчальних проєктах для створення 'розумних' ламп, фотореле або систем автоматичного зашторювання вікон.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51332" x="3400" y="40250" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="grove_temperature_sensor" modelIndex="1674" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/seeed_grove_temperature_sensor.fzp">
            <title>Назва: Grove Temperature Sensor</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51331" x="4250" y="40000"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1675" path=":/resources/parts/core/note.fzp">
            <title>Note344</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Grove Temperature Sensor&lt;/b&gt;&lt;br/&gt;Опис: Аналоговий датчик температури на базі термістора. Перетворює температуру навколишнього середовища в аналогову напругу. Використовується в базових метеостанціях та системах захисту від перегріву обладнання.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.5133" x="4250" y="40250" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="grove_infrared_receiver" modelIndex="1676" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/seeed_grove_infrared_receiver.fzp">
            <title>Назва: Grove IR Receiver</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51329" x="5100" y="40000"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1677" path=":/resources/parts/core/note.fzp">
            <title>Note345</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Grove IR Receiver&lt;/b&gt;&lt;br/&gt;Опис: Модуль інфрачервоного приймача для дистанційного керування. Здатен приймати сигнали зі стандартних ІЧ-пультів (наприклад, від телевізора). Дозволяє реалізувати бездротове керування роботами або домашньою автоматикою.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51328" x="5100" y="40250" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="grove_infrared_emitter" modelIndex="1678" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/seeed_grove_infrared_emitter.fzp">
            <title>Назва: Grove IR Emitter</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51327" x="5950" y="40000"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1679" path=":/resources/parts/core/note.fzp">
            <title>Note346</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Grove IR Emitter&lt;/b&gt;&lt;br/&gt;Опис: Модуль інфрачервоного передавача. Працює як пульт ДУ: випромінює ІЧ-світло на частоті 38 кГц. Використовується для створення універсальних пультів або для передачі даних між двома пристроями на короткій відстані.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51326" x="5950" y="40250" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="grove_buzz" modelIndex="1680" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/seeed_grove_buzz.fzp">
