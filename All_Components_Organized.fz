        <instance moduleIdRef="NoteModuleID" modelIndex="2152" path=":/resources/parts/core/note.fzp">
            <title>Note585</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: 6N138 (Оптопара з виходом Дарлінгтона)&lt;/b&gt;&lt;br/&gt;Опис: Високошвидкісний оптоізолятор, що використовує комбінацію фотодіода та транзистора Дарлінгтона. Забезпечує надвисокий коефіцієнт передачі струму (CTR). Ідеально підходить для розв'язки ліній зв'язку MIDI, цифрових інтерфейсів та керування низьковольтними реле.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50853" x="0" y="65150" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-DiscreteSemi-MMBZ27VCLT1-" modelIndex="2153" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-discretesemi-mmbz27vclt1-.fzp" flippedSMD="true">
            <title>Назва: MMBZ27VCL (Здвоєний стабілітрон ESD)</title>
            <views>
