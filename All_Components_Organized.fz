        <instance moduleIdRef="NoteModuleID" modelIndex="1094" path=":/resources/parts/core/note.fzp">
            <title>Note49</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: FLO-30 (Контролер потоку рідини)&lt;/b&gt;&lt;br/&gt;Опис: Просунутий інтерфейс для датчиків витрати води. На відміну від простого підрахунку імпульсів, модуль має вбудовану математичну модель для точного розрахунку миттєвої швидкості потоку та загального накопиченого об'єму. Підтримує роботу з турбінними та роторними витратомірами.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51911" x="4250" y="6350" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
