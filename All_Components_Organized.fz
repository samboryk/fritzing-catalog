                    <geometry z="6.50823" x="4250" y="65850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-DiscreteSemi-TCMT1103-OPTO-" modelIndex="2183" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-discretesemi-tcmt1103-opto-.fzp" flippedSMD="true">
