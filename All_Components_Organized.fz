        </instance>
        <instance moduleIdRef="LeDeuligne1.1" modelIndex="1689" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/LeDeuligne1.1.fzp">
