        <instance moduleIdRef="NoteModuleID" modelIndex="2154" path=":/resources/parts/core/note.fzp">
            <title>Note586</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MMBZ27VCL (Здвоєний стабілітрон ESD)&lt;/b&gt;&lt;br/&gt;Опис: Малопотужний обмежувач напруги (TVS-діод) у корпусі SOT-23. Призначений для захисту чутливих CMOS ліній вводу/виводу від електростатичних розрядів (ESD) та сплесків напруги. Забезпечує цілісність даних у цифрових шинах.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.50851" x="850" y="65150" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
