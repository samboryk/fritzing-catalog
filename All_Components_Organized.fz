        <instance moduleIdRef="NoteModuleID" modelIndex="1578" path=":/resources/parts/core/note.fzp">
            <title>Note295</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: PICAXE-28&lt;/b&gt;&lt;br/&gt;Опис: Повнорозмірний 28-піновий мікроконтролер. Має велику кількість аналогових та цифрових портів. Підходить для створення систем 'розумний дім' або складних верстатів на базі BASIC.&lt;/body&gt;&lt;/html&gt;</text>
