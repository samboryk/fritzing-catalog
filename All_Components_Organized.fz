        <instance moduleIdRef="NoteModuleID" modelIndex="2824" path=":/resources/parts/core/note.fzp">
            <title>Note924</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MyoWare Proto Shield&lt;/b&gt;&lt;br/&gt;Опис: Мініатюрна макетна плата для інтеграції датчика MyoWare. Дозволяє розпаяти додаткові компоненти (наприклад, світлодіоди або Bluetooth-модуль) безпосередньо в стек із основним сенсором.&lt;/body&gt;&lt;/html&gt;</text>
