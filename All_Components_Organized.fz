        <instance moduleIdRef="NoteModuleID" modelIndex="1096" path=":/resources/parts/core/note.fzp">
            <title>Note50</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: ENV-32X (Реєстратор даних пам'яті)&lt;/b&gt;&lt;br/&gt;Опис: Спеціалізована мікросхема флеш-пам'яті об'ємом 32 Мбіт, оптимізована для ведення логів. Розроблена для зберігання коротких рядків тексту (даних із сенсорів) без використання важких файлових систем. Має надзвичайно високу швидкість запису (3 мс) та гарантований термін зберігання даних 20 років.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51909" x="5100" y="6350" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
