        <instance moduleIdRef="NoteModuleID" modelIndex="1987" path=":/resources/parts/core/note.fzp">
            <title>Note502</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: ATxmega (Потужний 8/16-біт МК)&lt;/b&gt;&lt;br/&gt;Опис: Високопродуктивний мікроконтролер у 100-піновому корпусі. Має вбудовану систему подій (Event System), що дозволяє периферії спілкуватися між собою без участі процесора, значно підвищуючи швидкість реакції.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51018" x="850" y="57650" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
