            <title>Назва: Grove 4-Digit Display</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51319" x="850" y="40700"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1687" path=":/resources/parts/core/note.fzp">
            <title>Note350</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Grove 4-Digit Display&lt;/b&gt;&lt;br/&gt;Опис: Семисегментний індикатор на 4 цифри з драйвером TM1637. Використовує лише два піни для керування. Ідеально підходить для відображення цифрових даних, таких як час, температура або лічильники, не займаючи багато ресурсів мікроконтролера.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51318" x="850" y="40950" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1688" path=":/resources/parts/core/note.fzp">
            <title>Note351</title>
