        <instance moduleIdRef="NoteModuleID" modelIndex="2888" path=":/resources/parts/core/note.fzp">
            <title>Note956</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: ADXL345 Digital Accelerometer&lt;/b&gt;&lt;br/&gt;Опис: Цифровий трьохосьовий акселерометр (I2C/SPI). На відміну від аналогових моделей, дозволяє налаштовувати чутливість (±2g/4g/8g/16g) та генерувати переривання при виявленні подвійного кліку або падіння.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
