        <instance moduleIdRef="NoteModuleID" modelIndex="1690" path=":/resources/parts/core/note.fzp">
            <title>Note352</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: LeDeuligne v1.1 (LCD Shield)&lt;/b&gt;&lt;br/&gt;Опис: Компактний шилд із символьним дисплеєм (2 рядки по 16 символів), що використовує інтерфейс I2C для керування. Це дозволяє звільнити майже всі цифрові піни Arduino для інших потреб. Має вбудований 5-кнопковий джойстик, що робить його готовим рішенням для створення автономних меню та систем управління приладами.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51315" x="0" y="42850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="Memoire-1.0" modelIndex="1691" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/Memoire-1.0.fzp">
            <title>Назва: Memoire v1.0 (SD Card Shield)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51314" x="850" y="42600"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1692" path=":/resources/parts/core/note.fzp">
            <title>Note353</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Memoire v1.0 (SD Card Shield)&lt;/b&gt;&lt;br/&gt;Опис: Модуль для роботи з картами пам'яті SD/MMC. Призначений для ведення логів (data logging) та зберігання великих масивів даних. Має вбудований стабілізатор напруги та схему узгодження рівнів, що гарантує стабільну роботу з пам'яттю на високих швидкостях через інтерфейс SPI.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51313" x="850" y="42850" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="Power Screwshield 1.0a" modelIndex="1693" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/Power Screwshield 1.0a.fzp">
