            <title>Назва: ORP Circuit (Окисно-відновний потенціал)</title>
            <views>
                <breadboardView layer="breadboard">
                    <geometry z="2.51916" x="2550" y="6100"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1090" path=":/resources/parts/core/note.fzp">
            <title>Note47</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: ORP Circuit (Окисно-відновний потенціал)&lt;/b&gt;&lt;br/&gt;Опис: Науковий модуль для аналізу окислювальної здатності води. Використовується для моніторингу чистоти басейнів, якості питної води та в біореакторах. Працює за протоколами UART/I2C і дозволяє точно дозувати дезінфікуючі засоби (хлор, озон) на основі реальних хімічних показників.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51915" x="2550" y="6350" width="650" height="180"/>
                </breadboardView>
