        </instance>
        <instance moduleIdRef="83fdcaa81d3a1b40d252954136f96f24" modelIndex="1661" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/PIC_16F877A.fzp">
