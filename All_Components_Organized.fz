        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1475" path=":/resources/parts/core/note.fzp">
            <title>Note241</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: Гніздо JST VH (3-пін, Female)&lt;/b&gt;&lt;br/&gt;Опис: Відповідна частина для роз'єму JST VH. Має засувку для надійної фіксації кабелю в умовах сильної вібрації робота. Ідеально підходить для силових ліній живлення та з'єднань, де важлива механічна міцність роз'єму.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.5153" x="5950" y="24650" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
