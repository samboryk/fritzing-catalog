                    <geometry z="2.51303" x="1700" y="44500"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="NoteModuleID" modelIndex="1703" path=":/resources/parts/core/note.fzp">
            <title>Note359</title>
            <text>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style='font-family: Arial; font-size: 12px;'&gt;&lt;b&gt;Назва: MSGEQ7 (Графічний еквалайзер)&lt;/b&gt;&lt;br/&gt;Опис: Семисмуговий графічний аналізатор аудіоспектру. Розділяє вхідний аудіосигнал на 7 частотних смуг (63Гц, 160Гц, 400Гц, 1кГц, 2.5кГц, 6.25кГц, 16кГц) і видає їх амплітуду. Використовується для створення світломузики та візуалізаторів звуку.&lt;/body&gt;&lt;/html&gt;</text>
            <views>
                <breadboardView layer="breadboardNote">
                    <geometry z="6.51302" x="1700" y="44750" width="650" height="180"/>
                </breadboardView>
            </views>
        </instance>
        <instance moduleIdRef="SparkFun-AnalogIC-AD7302-SMD" modelIndex="1704" path="C:/Users/dmytr/Downloads/Fritzing  0.9.4.64/fritzing.0.9.4.64.pc/fritzing-parts/core/sparkfun-analogic-ad7302-smd.fzp" flippedSMD="true">
            <title>Назва: AD7302 (Подвійний ЦАП 8-біт)</title>
            <views>
